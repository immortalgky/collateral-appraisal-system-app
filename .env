# API URL for the backend
VITE_API_URL=https://localhost:7111
VITE_APP_URL=https://localhost:3000

# API delay for development (in milliseconds) - set to 0 for production
VITE_API_DELAY=500

# Google Maps API Key
# Required by src/features/common/historySearch/components/MapView.tsx
# DO NOT put a real key here — `.env` is tracked. Put the real key in `.env.local`
# (gitignored). Vite reads `.env.local` and overrides `.env` automatically.
# Create a key at https://console.cloud.google.com/ (Maps JavaScript API).
# Restrict by HTTP Referer in production.
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Map ID (optional — needed for AdvancedMarker, falls back to legacy Marker)
# VITE_GOOGLE_MAPS_MAP_ID=

# Add other environment variables as needed
VITE_HTTPS_KEY_PATH=/Users/gky/localhost-key.pem
VITE_HTTPS_CERT_PATH=/Users/gky/localhost.pem
