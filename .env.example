# Copy to `.env.local` (gitignored) and fill in real values.
# Vite reads `.env.local` and overrides `.env`/`.env.example` automatically.

# API URL for the backend
VITE_API_URL=https://localhost:7111
VITE_APP_URL=https://localhost:3000

# API delay for development (in milliseconds) - set to 0 for production
VITE_API_DELAY=500

# Google Maps JS API key — required by the History Search / pricing maps.
# Put the real value in .env.local. Create one at
# https://console.cloud.google.com/ (Maps JavaScript API); restrict by HTTP Referer.
VITE_GOOGLE_MAPS_API_KEY=
# Optional Map ID for AdvancedMarker support
# VITE_GOOGLE_MAPS_MAP_ID=

# HTTPS dev cert paths — point these at YOUR local mkcert files (machine-specific).
# e.g. generate with `mkcert localhost` and set the paths in .env.local.
VITE_HTTPS_KEY_PATH=./localhost-key.pem
VITE_HTTPS_CERT_PATH=./localhost.pem
