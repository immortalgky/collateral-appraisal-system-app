<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for the built SPA (Vite copies public/* into dist/, so this
  lands at the deployed site root).

  ⚠️ DEPLOY NOTE: this file becomes the site-root web.config. If the IIS site
  already has a hand-maintained web.config (e.g. an existing SPA rewrite, auth,
  or header rules), RECONCILE the two before deploying — do not let this blindly
  overwrite server-managed settings. Coordinate the compression MIME registration
  with infra (see <httpCompression> note below).

  What this does:
    1. Static compression for text assets, including the Font Awesome SVG sprite
       sheets in /icons (XML text → ~75-85% smaller on the wire). The icon files
       are intentionally NOT trimmed (the menu IconPicker lets admins pick any FA
       icon/style at runtime), so compression is the delivery-side win.
    2. Long cache headers for immutable, fingerprinted assets and the icon/marker
       static files.
    3. SPA fallback: serve index.html for client-side routes (deep links / refresh).
-->
<configuration>
  <system.webServer>

    <!--
      Enable static compression. NOTE: registering image/svg+xml in the static
      compression scheme is often locked at applicationHost.config (server level);
      if SVG still isn't compressed after deploy, infra must add image/svg+xml to
      <httpCompression><staticTypes> at the server level. The <urlCompression>
      switch below is settable per-site and is the part we control here.
    -->
    <urlCompression doStaticCompression="true" doDynamicCompression="false" />
    <httpCompression>
      <staticTypes>
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/manifest+json" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>

    <staticContent>
      <!-- Ensure SVG is served with the correct type (needed for compression + <use>). -->
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <!-- DEFAULT = no long cache. This covers index.html AND every route URL the
           SPA rewrite serves index.html for. index.html is NOT fingerprinted and
           references hash-named code-split chunks, so it must always revalidate —
           otherwise a deploy leaves cached shells pointing at deleted chunk hashes
           and lazy import() 404s. Long caching is re-enabled per-folder below for
           the fingerprinted /assets and the rarely-changing /icons + /markers. -->
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- SPA fallback: any request that is not an existing file or directory
             is served index.html so React Router handles the path client-side. -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>

  <!-- Vite fingerprints everything in /assets (hash in filename), so a file at a
       given URL is immutable — cache for a year. -->
  <location path="assets">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

  <!-- Icon sprites and map markers are not fingerprinted but change rarely; cache
       a week so they're not refetched every navigation, while still refreshing
       within a reasonable window after an icon update. -->
  <location path="icons">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="markers">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
